{
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"editor.inlineSuggest.suppressSuggestions": true,
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.eol": "\r\n",
	"extensions.allowed": {
		"GitHub.copilot-chat": false
	},
	"telemetry.telemetryLevel": "off",
	"html.format.wrapLineLength": 360,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,
	"js/ts.format.semicolons": "remove",
	"js/ts.preferences.quoteStyle": "double",
	"js/ts.inlayHints.parameterNames.enabled": "none",
	"js/ts.inlayHints.enumMemberValues.enabled": false,
	"js/ts.inlayHints.functionLikeReturnTypes.enabled": false,
	"js/ts.inlayHints.parameterTypes.enabled": false,
	"js/ts.inlayHints.propertyDeclarationTypes.enabled": false,
	"js/ts.inlayHints.variableTypes.enabled": false,
	"js/ts.inlayHints.variableTypes.suppressWhenTypeMatchesName": false,
	"deno.unstable": true,
	"deno.enable": true,
	"deno.disablePaths": [
		"**/package.json"
	],
	"xml.format.maxLineWidth": 800,
	"xml.format.splitAttributesIndentSize": 1,
	"xml.format.splitAttributes": "splitNewLine",
	"xml.format.joinContentLines": true,
	"xml.format.legacy": true
}
